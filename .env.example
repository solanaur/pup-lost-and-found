# Required in production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Supabase (required for Netlify deploy — get from Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# AI — Gemini free tier (recommended): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash



# Server
PORT=3000
# Production: your public URL (e.g. https://ibalik.example.com or http://<vm-ip>:3000)
PUBLIC_BASE_URL=http://localhost:3000

# Gmail SMTP — required on Netlify for confirmation emails (Site settings → Environment variables)
# 1. Sign in to pupibaliklostandfound@gmail.com
# 2. Enable 2-Step Verification: https://myaccount.google.com/security
# 3. Create an App Password: https://myaccount.google.com/apppasswords
# 4. Paste the 16-character app password below (not your Gmail login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=pupibaliklostandfound@gmail.com
SMTP_PASS=
EMAIL_FROM=iBALIK <pupibaliklostandfound@gmail.com>

# Legacy MySQL backend (optional — primary app uses data/store.json)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=pup_lost_found
CORS_ORIGINS=*
